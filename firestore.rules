rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function getUserData() { return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : {}; }
    function isNotBanned() { return getUserData().get('isBanned', false) == false; }
    function isSuperAdmin() { return isSignedIn() && getUserData().get('isSuperAdmin', false) == true; }
    
    // 🔥 SECURITY FIX: Prevent megabyte-sized text uploads from crashing the app
    function isValidText(text, maxLen) {
      return text is string && text.size() <= maxLen;
    }
    
    function canDeleteGlobalPubs() {
      return isSuperAdmin() || (isSignedIn() && getUserData().get('isAdmin', false) == true) || (isSignedIn() && getUserData().get('permissions', {}).get('canDeletePubs', false) == true);
    }
    function canModerate() {
      return canDeleteGlobalPubs() || (isSignedIn() && getUserData().get('isModerator', false) == true) || (isSignedIn() && getUserData().get('permissions', {}).get('canModeratePhotos', false) == true);
    }
    function canEditConfig() {
      return isSuperAdmin() || (isSignedIn() && getUserData().get('isAdmin', false) == true) || (isSignedIn() && getUserData().get('permissions', {}).get('canEditConfig', false) == true);
    }

    function isModifyingOwnMembership() {
      let diff = request.resource.data.diff(resource.data);
      let onlyMembersChanged = diff.affectedKeys().hasOnly(['members']);
      let onlyPendingChanged = diff.affectedKeys().hasOnly(['pendingMembers']);
      let joiningMembers = onlyMembersChanged && resource.data.get('requireApproval', false) == false && (request.auth.uid in request.resource.data.members);
      let leavingMembers = onlyMembersChanged && !(request.auth.uid in request.resource.data.members);
      let joiningPending = onlyPendingChanged && (request.auth.uid in request.resource.data.pendingMembers);
      return joiningMembers || leavingMembers || joiningPending;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId && !('isSuperAdmin' in request.resource.data) && !('isAdmin' in request.resource.data) && !('isModerator' in request.resource.data) && !('permissions' in request.resource.data) && !('assignedRole' in request.resource.data);
      allow update: if (isSignedIn() && request.auth.uid == userId && isNotBanned() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isSuperAdmin', 'isAdmin', 'isModerator', 'isBanned', 'permissions', 'assignedRole'])) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /groups/{groupId} {
      allow read: if true; 
      allow create: if isSignedIn() && isNotBanned(); 
      allow update, delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && (resource.data.ownerUid == request.auth.uid || request.auth.uid in resource.data.get('managers', []) || isModifyingOwnMembership()));

      match /auditLogs/{logId} {
         allow read, create: if isSuperAdmin() || (isSignedIn() && isNotBanned() && (get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('managers', [])));
         allow update, delete: if false; 
      }
      match /scores/{scoreId} {
         allow read: if true;
         allow create: if isSignedIn() && isNotBanned() && request.resource.data.userId == request.auth.uid;
         allow update: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid);
         allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid);
         match /comments/{commentId} {
            allow read: if true;
            allow create: if isSignedIn() && isNotBanned() && request.resource.data.userId == request.auth.uid;
            allow update: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid);
            allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid);
         }
      }
    }

    match /{path=**}/pubs/{pubId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBanned();
      allow update: if canDeleteGlobalPubs() || (isSignedIn() && isNotBanned() && (
          resource.data.get('isLocked', false) == false ||
          (resource.data.get('claimedBy', []) is list && request.auth.uid in resource.data.get('claimedBy', []))
      )); 
      allow delete: if canDeleteGlobalPubs(); 
    }

    match /{path=**}/criteria/{critId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isNotBanned(); 
      allow delete: if canDeleteGlobalPubs(); 
    }

    match /{path=**}/scores/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn() && isNotBanned() && request.resource.data.userId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid);
      allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid);
    }

    // ✓ FIX: field names now match MapPage saveCrawl()
    //   - creatorId  (was: createdBy)
    //   - pubIds     (was: route)
    match /crawls/{crawlId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && isNotBanned()
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.pubIds is list
                    && request.resource.data.pubIds.size() >= 2
                    && request.resource.data.pubIds.size() <= 30;
      allow update, delete: if isSuperAdmin()
                             || (isSignedIn() && isNotBanned() && resource.data.creatorId == request.auth.uid);
    }
    
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isNotBanned(); 
      allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.createdBy == request.auth.uid); 
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && isNotBanned();
      allow read, update, delete: if canModerate(); 
    }

    match /global/{docId} {
      allow read: if true; 
      allow write: if canEditConfig(); 
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isNotBanned(); 
      allow read, update, delete: if canEditConfig(); 
    }

    match /venueClaims/{claimId} {
      allow create: if isSignedIn() && isNotBanned();
      allow read, update, delete: if canEditConfig();
    }
  }
}
