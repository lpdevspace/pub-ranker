rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    // ────────────────────────────────────────────────────────────
    // PRIVILEGE CHECKS — read from Firebase Auth Custom Claims only.
    // Custom Claims are set server-side (Cloud Function / Admin SDK)
    // and cannot be tampered with from the client.
    // ────────────────────────────────────────────────────────────
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.get('isSuperAdmin', false) == true;
    }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.get('isSuperAdmin', false) == true ||
        request.auth.token.get('isAdmin', false) == true
      );
    }
    function isModerator() {
      return isSignedIn() && (
        request.auth.token.get('isSuperAdmin', false) == true ||
        request.auth.token.get('isAdmin', false) == true ||
        request.auth.token.get('isModerator', false) == true
      );
    }

    // Keep getUserData() only for non-privilege fields (isBanned, permissions).
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : {};
    }
    function isNotBanned() { return getUserData().get('isBanned', false) == false; }

    // ────────────────────────────────────────────────────────────
    // INPUT VALIDATION HELPERS
    // ────────────────────────────────────────────────────────────
    function isValidText(text, maxLen) {
      return text is string && text.size() <= maxLen;
    }
    function isValidOptionalText(data, field, maxLen) {
      return !(field in data) || (data[field] is string && data[field].size() <= maxLen);
    }

    // ────────────────────────────────────────────────────────────
    // RATE LIMITING HELPER
    // NOTE: /rateLimits/{userId} is now READ-ONLY from the client.
    // The lastScoreAt timestamp is written exclusively by the
    // onScoreCreate Cloud Function so it cannot be reset by the user.
    // ────────────────────────────────────────────────────────────
    function notRateLimited() {
      let rateDoc = /databases/$(database)/documents/rateLimits/$(request.auth.uid);
      return !exists(rateDoc) ||
             get(rateDoc).data.get('lastScoreAt', 0) < (request.time.toMillis() - 30000);
    }

    function canDeleteGlobalPubs() {
      return isAdmin() || (isSignedIn() && getUserData().get('permissions', {}).get('canDeletePubs', false) == true);
    }
    function canModerate() {
      return canDeleteGlobalPubs() || isModerator() || (isSignedIn() && getUserData().get('permissions', {}).get('canModeratePhotos', false) == true);
    }
    function canEditConfig() {
      return isAdmin() || (isSignedIn() && getUserData().get('permissions', {}).get('canEditConfig', false) == true);
    }

    function isModifyingOwnMembership() {
      let diff = request.resource.data.diff(resource.data);
      let onlyMembersChanged = diff.affectedKeys().hasOnly(['members']);
      let onlyPendingChanged = diff.affectedKeys().hasOnly(['pendingMembers']);
      let joiningMembers = onlyMembersChanged && resource.data.get('requireApproval', false) == false && (request.auth.uid in request.resource.data.members);
      let leavingMembers = onlyMembersChanged && !(request.auth.uid in request.resource.data.members);
      let joiningPending = onlyPendingChanged && (request.auth.uid in request.resource.data.pendingMembers);
      return joiningMembers || leavingMembers || joiningPending;
    }

    // ────────────────────────────────────────────────────────────
    // USERS
    // ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId
        && !('isSuperAdmin' in request.resource.data)
        && !('isAdmin' in request.resource.data)
        && !('isModerator' in request.resource.data)
        && !('permissions' in request.resource.data)
        && !('assignedRole' in request.resource.data);
      allow update: if (isSignedIn() && request.auth.uid == userId && isNotBanned()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isSuperAdmin', 'isAdmin', 'isModerator', 'isBanned', 'permissions', 'assignedRole'])
        && isValidOptionalText(request.resource.data, 'displayName', 60)
        && isValidOptionalText(request.resource.data, 'bio', 300)
      ) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /public/{docId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['displayName', 'nickname', 'photoURL']);
      }
    }

    // ────────────────────────────────────────────────────────────
    // RATE LIMITS — CLIENT READ-ONLY.
    // Writes come exclusively from the onScoreCreate Cloud Function
    // via the Firebase Admin SDK (bypasses these rules entirely).
    // Removing the client write rule prevents users from resetting
    // lastScoreAt to 0 to bypass the 30-second cooldown.
    // ────────────────────────────────────────────────────────────
    match /rateLimits/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    // ────────────────────────────────────────────────────────────
    // GROUPS
    // ────────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        request.auth.uid in resource.data.get('members', []) ||
        request.auth.uid in resource.data.get('pendingMembers', []) ||
        resource.data.ownerUid == request.auth.uid
      );
      allow create: if isSignedIn() && isNotBanned();
      allow update: if isSuperAdmin() || (
        isSignedIn() && isNotBanned() && (
          isModifyingOwnMembership() ||
          (
            resource.data.ownerUid == request.auth.uid ||
            request.auth.uid in resource.data.get('managers', [])
          )
        )
      );
      allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.ownerUid == request.auth.uid);

      match /auditLogs/{logId} {
         allow read, create: if isSuperAdmin() || (isSignedIn() && isNotBanned() && (get(/databases/$(database)/documents/groups/$(groupId)).data.ownerUid == request.auth.uid || request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('managers', [])));
         allow update, delete: if false;
      }
      match /scores/{scoreId} {
         allow read: if isSignedIn() && (
           isSuperAdmin() ||
           request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.get('members', [])
         );
         allow create: if isSignedIn() && isNotBanned()
           && request.resource.data.userId == request.auth.uid
           && notRateLimited()
           && request.resource.data.value is number
           && request.resource.data.value >= 0
           && request.resource.data.value <= 10;
         allow update: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid);
         allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid);
         match /comments/{commentId} {
            allow read: if isSignedIn();
            allow create: if isSignedIn() && isNotBanned()
              && request.resource.data.userId == request.auth.uid
              && isValidText(request.resource.data.text, 500);
            allow update: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid && isValidText(request.resource.data.text, 500));
            allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid);
         }
      }
    }

    match /{path=**}/pubs/{pubId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned()
        && isValidText(request.resource.data.name, 120)
        && isValidOptionalText(request.resource.data, 'address', 200);
      allow update: if canDeleteGlobalPubs() || (isSignedIn() && isNotBanned() && (
          resource.data.get('isLocked', false) == false ||
          (resource.data.get('claimedBy', []) is list && request.auth.uid in resource.data.get('claimedBy', []))
      ));
      allow delete: if canDeleteGlobalPubs();
    }

    match /{path=**}/criteria/{critId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isNotBanned()
        && isValidOptionalText(request.resource.data, 'name', 80);
      allow delete: if canDeleteGlobalPubs();
    }

    match /{path=**}/scores/{scoreId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned()
        && request.resource.data.userId == request.auth.uid
        && notRateLimited()
        && request.resource.data.value is number
        && request.resource.data.value >= 0
        && request.resource.data.value <= 10;
      allow update: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid);
      allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.userId == request.auth.uid);
    }

    match /crawls/{crawlId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && isNotBanned()
                    && request.resource.data.creatorId == request.auth.uid
                    && request.resource.data.pubIds is list
                    && request.resource.data.pubIds.size() >= 2
                    && request.resource.data.pubIds.size() <= 30
                    && isValidOptionalText(request.resource.data, 'name', 100);
      allow update, delete: if isSuperAdmin()
                             || (isSignedIn() && isNotBanned() && resource.data.creatorId == request.auth.uid);
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isNotBanned()
        && isValidText(request.resource.data.title, 80)
        && isValidOptionalText(request.resource.data, 'description', 500);
      allow delete: if isSuperAdmin() || (isSignedIn() && isNotBanned() && resource.data.createdBy == request.auth.uid);
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && isNotBanned()
        && isValidOptionalText(request.resource.data, 'reason', 300);
      allow read, update, delete: if canModerate();
    }

    match /global/{docId} {
      allow read: if isSignedIn();
      allow write: if canEditConfig();
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isNotBanned()
        && isValidText(request.resource.data.message, 1000);
      allow read, update, delete: if canEditConfig();
    }

    match /venueClaims/{claimId} {
      allow create: if isSignedIn() && isNotBanned();
      allow read, update, delete: if canEditConfig();
    }
  }
}
